<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FinancialBuddy" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorPrimary">#3b82f6</item>
        <item name="colorPrimaryVariant">#1d4ed8</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSurface">#000000</item>
        <item name="colorOnSurface">#F1F5F9</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
    </style>

    <!-- Transparent activity for permission trampoline -->
    <style name="Theme.Transparent" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Dark-themed AlertDialog -->
    <style name="DarkAlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">#1a1a1a</item>
        <item name="colorPrimary">#3b82f6</item>
        <item name="android:textColorPrimary">#F1F5F9</item>
        <item name="android:textColorSecondary">#94A3B8</item>
        <item name="buttonBarPositiveButtonStyle">@style/BlueButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/GhostButton</item>
    </style>

    <style name="BlueButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#3b82f6</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="GhostButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#64748B</item>
    </style>

</resources>

<!-- Suppress tools namespace warning -->
<resources xmlns:tools="http://schemas.android.com/tools" />
